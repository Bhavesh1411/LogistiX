<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    ============================================================
    LogistiX Record Rules
    ============================================================
    Principle  : Least Privilege + Explicit Group Scoping
    Design     : Avoid [(1,'=',1)] where possible.
                 All rules are scoped to specific groups.
                 Only Administrator effectively has unrestricted access.
    Multi-co   : company_id field guards are structurally commented
                 and ready for future multi-company activation.
    ============================================================
    -->

    <!-- ================================================================
         MODEL: logistix.trip
         ================================================================ -->

    <!-- Placeholder for Future: Trip Approval Workflow Rules -->
    <!-- Examples: Draft -> Submitted -> Approved -> In Transit -->

    <!-- Rule: Administrator — Full access to all trips -->
    <record id="rule_logistix_trip_admin_all" model="ir.rule">
        <field name="name">Trips: Administrator Full Access</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Fleet Manager — Full access to all trips -->
    <record id="rule_logistix_trip_fleet_manager_all" model="ir.rule">
        <field name="name">Trips: Fleet Manager Full Access</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_fleet_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Dispatcher — Create and update trips; cannot delete historical trips -->
    <record id="rule_logistix_trip_dispatcher_no_delete" model="ir.rule">
        <field name="name">Trips: Dispatcher Create and Update Only</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_dispatcher'))]"/>
        <field name="domain_force">[('trip_status', '!=', 'completed')]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Dispatcher — Read all trips (including completed/historical) -->
    <record id="rule_logistix_trip_dispatcher_read_all" model="ir.rule">
        <field name="name">Trips: Dispatcher Read All</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_dispatcher'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Finance Manager — Read all trips for revenue/cost analysis -->
    <record id="rule_logistix_trip_finance_manager_read" model="ir.rule">
        <field name="name">Trips: Finance Manager Read All</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_finance_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Driver — Can access only their own trips -->
    <record id="rule_logistix_trip_driver_own" model="ir.rule">
        <field name="name">Trips: Driver Own Trips Only</field>
        <field name="model_id" ref="model_logistix_trip"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_driver'))]"/>
        <!-- Link logged-in user → hr.employee.user_id → logistix.trip.driver_id -->
        <!-- If user is not linked to hr.employee, this evaluates to False, denying access securely. -->
        <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================================
         MODEL: logistix.vehicle.document
         ================================================================ -->

    <!-- Rule: Administrator — Full access to all vehicle documents -->
    <record id="rule_logistix_vehicle_document_admin_all" model="ir.rule">
        <field name="name">Vehicle Documents: Administrator Full Access</field>
        <field name="model_id" ref="model_logistix_vehicle_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Fleet Manager — Full access to all vehicle documents -->
    <record id="rule_logistix_vehicle_document_fleet_manager_all" model="ir.rule">
        <field name="name">Vehicle Documents: Fleet Manager Full Access</field>
        <field name="model_id" ref="model_logistix_vehicle_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_fleet_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Dispatcher — Read all vehicle documents (reference only) -->
    <record id="rule_logistix_vehicle_document_dispatcher_read" model="ir.rule">
        <field name="name">Vehicle Documents: Dispatcher Read All</field>
        <field name="model_id" ref="model_logistix_vehicle_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_dispatcher'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================================
         MODEL: logistix.driver.document
         ================================================================ -->

    <!-- Rule: Administrator — Full access to all driver documents -->
    <record id="rule_logistix_driver_document_admin_all" model="ir.rule">
        <field name="name">Driver Documents: Administrator Full Access</field>
        <field name="model_id" ref="model_logistix_driver_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Fleet Manager — Full access to all driver documents -->
    <record id="rule_logistix_driver_document_fleet_manager_all" model="ir.rule">
        <field name="name">Driver Documents: Fleet Manager Full Access</field>
        <field name="model_id" ref="model_logistix_driver_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_fleet_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Dispatcher — Read all driver documents (reference only) -->
    <record id="rule_logistix_driver_document_dispatcher_read" model="ir.rule">
        <field name="name">Driver Documents: Dispatcher Read All</field>
        <field name="model_id" ref="model_logistix_driver_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_dispatcher'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Driver — Can access only their own compliance documents -->
    <record id="rule_logistix_driver_document_driver_own" model="ir.rule">
        <field name="name">Driver Documents: Driver Own Documents Only</field>
        <field name="model_id" ref="model_logistix_driver_document"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_driver'))]"/>
        <!-- Link logged-in user → hr.employee.user_id → logistix.driver.document.driver_id -->
        <!-- If user is not linked to hr.employee, this evaluates to False, denying access securely. -->
        <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================================
         MODEL: logistix.notification
         Notifications are system-generated.
         Drivers are read-only and see only notifications addressed to them.
         ================================================================ -->

    <!-- Rule: Administrator — Full access to all notifications -->
    <record id="rule_logistix_notification_admin_all" model="ir.rule">
        <field name="name">Notifications: Administrator Full Access</field>
        <field name="model_id" ref="model_logistix_notification"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Fleet Manager — Full access to all notifications -->
    <record id="rule_logistix_notification_fleet_manager_all" model="ir.rule">
        <field name="name">Notifications: Fleet Manager Full Access</field>
        <field name="model_id" ref="model_logistix_notification"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_fleet_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule: Dispatcher — Create and read notifications (no delete of system records) -->
    <record id="rule_logistix_notification_dispatcher_create" model="ir.rule">
        <field name="name">Notifications: Dispatcher Read and Create</field>
        <field name="model_id" ref="model_logistix_notification"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_dispatcher'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Driver — Read only their own notifications -->
    <record id="rule_logistix_notification_driver_own" model="ir.rule">
        <field name="name">Notifications: Driver Own Notifications Only</field>
        <field name="model_id" ref="model_logistix_notification"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_driver'))]"/>
        <!--
            Notifications created by or for the logged-in driver.
            Currently uses create_uid as a proxy for ownership.
            FUTURE MIGRATION: Shift to relation-based ownership using
            ['|', ('related_model', '=', 'logistix.trip'), ('related_record_id', '=', trip.id)] 
            or similar when models are linked.
        -->
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================================
         MODEL: logistix.audit.log
         Audit Logs are immutable by design.
         No write. No delete. Only Administrator can read and create.
         No record rules for other groups (ACL blocks access entirely).
         ================================================================ -->

    <!-- Placeholder for Future: Expense Approval Workflow -->
    <!-- Examples: Draft -> Submitted -> Approved by Finance -> Paid -->

    <!-- Placeholder for Future: Maintenance Approval Workflow -->
    <!-- Examples: Requested -> Fleet Manager Approved -> In Progress -> Done -->

    <!-- Rule: Administrator — Read and Create audit logs (no modify, no delete) -->
    <record id="rule_logistix_audit_log_admin_immutable" model="ir.rule">
        <field name="name">Audit Log: Administrator Read and Create Only</field>
        <field name="model_id" ref="model_logistix_audit_log"/>
        <field name="groups" eval="[(4, ref('logistix.group_logistix_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
