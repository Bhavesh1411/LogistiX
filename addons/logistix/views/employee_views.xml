<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
    ======================================================================
    LogistiX Driver (hr.employee) Inherited Views
    ======================================================================
    Extends native employee views to inject driver licensing, compliance,
    safety performance metrics, and history notebook pages.
    ======================================================================
    -->

    <!-- Tree View Inheritance -->
    <record id="view_employee_tree_inherit" model="ir.ui.view">
        <field name="name">hr.employee.tree.inherit.logistix</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <!-- Append key licensing and availability details to the list view -->
            <xpath expr="//field[@name='work_email']" position="before">
                <field name="licence_no" optional="show"/>
                <field name="license_expiry" optional="show"/>
                <field name="safety_rating" optional="show"/>
                <field name="availability_status" widget="badge" 
                       decoration-success="availability_status == 'available'" 
                       decoration-danger="availability_status == 'unavailable'" 
                       decoration-warning="availability_status == 'leave'"/>
            </xpath>
        </field>
    </record>

    <!-- Form View Inheritance -->
    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.logistix</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Header for Driver Availability and Placeholder Actions -->
            <xpath expr="//header" position="inside">
                <field name="availability_status" widget="statusbar" statusbar_visible="available,unavailable,leave"/>
            </xpath>

            <!-- Inject licensing, performance, and risk metrics in form body -->
            <xpath expr="//sheet" position="inside">
                <group string="LogistiX Driver Compliance &amp; Safety" name="driver_compliance" col="4">
                    <field name="licence_no"/>
                    <field name="license_expiry"/>
                    <field name="experience_years"/>
                    <field name="blood_group"/>
                    <field name="safety_rating"/>
                    <field name="performance_score"/>
                    <field name="risk_score"/>
                    <field name="emergency_contact"/>
                </group>
                
                <notebook position="inside">
                    <page string="Trips Catalog" name="driver_trips">
                        <field name="trip_ids" mode="tree" readonly="True">
                            <tree>
                                <field name="name"/>
                                <field name="vehicle_id"/>
                                <field name="origin"/>
                                <field name="destination"/>
                                <field name="dispatch_time"/>
                                <field name="trip_status" widget="badge"/>
                                <field name="revenue"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Driver Documents" name="driver_docs">
                        <field name="document_ids" mode="tree" readonly="True">
                            <tree>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="issue_date"/>
                                <field name="expiry_date"/>
                                <field name="document_status" widget="badge" 
                                       decoration-success="document_status == 'active'" 
                                       decoration-danger="document_status == 'expired'"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
