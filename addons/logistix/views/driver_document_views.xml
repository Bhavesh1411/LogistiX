<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
    ======================================================================
    LogistiX Driver Document Views (Tree, Form)
    ======================================================================
    Contains core views for tracking driver compliance certifications.
    ======================================================================
    -->

    <!-- Tree View: logistix.driver.document -->
    <record id="view_logistix_driver_document_tree" model="ir.ui.view">
        <field name="name">logistix.driver.document.tree</field>
        <field name="model">logistix.driver.document</field>
        <field name="arch" type="xml">
            <tree string="Driver Compliance Documents">
                <field name="name" string="Document Ref"/>
                <field name="driver_id"/>
                <field name="document_type"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="document_status" widget="badge" 
                       decoration-success="document_status == 'active'" 
                       decoration-danger="document_status == 'expired'"/>
            </tree>
        </field>
    </record>

    <!-- Form View: logistix.driver.document -->
    <record id="view_logistix_driver_document_form" model="ir.ui.view">
        <field name="name">logistix.driver.document.form</field>
        <field name="model">logistix.driver.document</field>
        <field name="arch" type="xml">
            <form string="Driver Document Details">
                <!-- Header Statusbar & Placeholder Actions -->
                <header>
                    <!-- Future action to trigger manual expiration state check -->
                    <button name="action_check_expiration" string="Check Expiry" type="object"/>
                    <field name="document_status" widget="statusbar" statusbar_visible="active,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. DL-IND-12345"/>
                        </h1>
                    </div>
                    
                    <group id="general_info">
                        <group string="Identity" id="left_identity">
                            <field name="driver_id"/>
                            <field name="document_type"/>
                        </group>
                        <group string="Validity" id="right_validity">
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter tracking -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
